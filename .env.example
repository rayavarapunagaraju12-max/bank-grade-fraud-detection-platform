APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=replace-with-secret-manager-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
ENABLE_API_KEY_AUTH=true
DEMO_API_KEY=replace-with-secret-manager-value

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ENABLED=true
TRANSACTIONS_TOPIC=transactions
FEATURES_TOPIC=features
ALERTS_TOPIC=fraud-alerts
KAFKA_CONSUMER_GROUP=fraud-detection

REDIS_URL=redis://redis:6379/0
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fraud
POSTGRES_USER=fraud
POSTGRES_PASSWORD=replace-with-secret-manager-value
DATABASE_URL=postgresql+psycopg://fraud:${POSTGRES_PASSWORD}@postgres:5432/fraud

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-secret-manager-value

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=fraudadmin
MINIO_SECRET_KEY=replace-with-secret-manager-value
MINIO_BUCKET=models

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
GENERATE_LLM_NARRATIVE_INLINE=false

PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
CORS_ORIGINS=http://localhost:5173,http://frontend:5173
